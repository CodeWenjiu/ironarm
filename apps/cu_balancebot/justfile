# BalanceBot automation helpers.

bevy:
  #!/usr/bin/env bash
  set -euo pipefail
  cargo run --features bevymon --bin balancebot-bevymon

web:
  #!/usr/bin/env bash
  set -euo pipefail
  trunk serve --open index.html

web-dist:
  #!/usr/bin/env bash
  set -euo pipefail
  trunk build --release --dist dist/balancebot index.html

balancebot-dump-text-logs:
  #!/usr/bin/env bash
  set -euo pipefail
  cargo run --features logreader --bin balancebot-logreader -- \
    logs/balance.copper extract-text-log target/debug/cu29_log_index

balancebot-fsck:
  #!/usr/bin/env bash
  set -euo pipefail
  cargo run --features logreader --bin balancebot-logreader -- \
    logs/balance.copper fsck

balancebot-set-pwm-permissions:
  #!/usr/bin/env bash
  set -euo pipefail
  echo "Setting PWM permissions..."
  # Hardware-specific: adjust paths for your target
  echo "Run on target: chmod 666 /sys/class/pwm/pwmchip0/pwm0/duty_cycle"

dag-logstats:
  #!/usr/bin/env bash
  set -euo pipefail
  cu29-rendercfg copperconfig.ron --logstats --open

resim:
  #!/usr/bin/env bash
  set -euo pipefail
  cargo run --no-default-features --features sim-debug --bin balancebot-resim --release

resim-debug:
  #!/usr/bin/env bash
  set -euo pipefail
  cargo run --no-default-features --features sim-debug --bin balancebot-resim --release -- \
    --serve-debug
