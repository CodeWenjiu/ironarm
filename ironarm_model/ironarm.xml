<mujoco model="ironarm">
  <compiler angle="radian"/>

  <visual>
    <global offwidth="2048" offheight="2048"/>
  </visual>

  <worldbody>
    <!-- Floor (X-Y plane, Z=0) -->
    <geom type="plane" size="3 3 0.1" rgba="0.28 0.28 0.32 1"/>

    <!-- Base pedestal -->
    <body name="base" pos="0 0 0">
      <geom type="cylinder" size="0.06 0.12" pos="0 0 0.06" rgba="0.45 0.45 0.50 1"/>
      <geom type="box" size="0.1 0.005 0.1" pos="0 0 0.005" rgba="0.40 0.40 0.42 1"/>
    </body>

    <!-- Shoulder (base rotation around Z) -->
    <body name="shoulder" pos="0 0 0.15">
      <joint name="j0" type="hinge" axis="0 0 1"/>
      <geom type="sphere" size="0.04" rgba="0.80 0.80 0.80 1"/>
      <!-- Upper arm (extends along +X) -->
      <body name="upper_arm" pos="0 0 0">
        <geom type="capsule" size="0.035" fromto="0 0 0 1.0 0 0" rgba="0.35 0.65 0.95 1"/>
        <!-- Elbow (pitch around Y) -->
        <body name="elbow" pos="1.0 0 0">
          <joint name="j1" type="hinge" axis="0 1 0"/>
          <geom type="sphere" size="0.04" rgba="0.80 0.80 0.80 1"/>
          <!-- Forearm (extends along +X, folds in XZ plane) -->
          <body name="forearm" pos="0 0 0">
            <geom type="capsule" size="0.03" fromto="0 0 0 2.0 0 0" rgba="0.35 0.75 0.45 1"/>
            <!-- Wrist -->
            <body name="wrist" pos="2.0 0 0">
              <geom type="sphere" size="0.03" rgba="0.80 0.80 0.80 1"/>
            </body>
          </body>
        </body>
      </body>
    </body>

    <!-- Target marker -->
    <body name="target" pos="1.2 0 0.65">
      <freejoint/>
      <geom type="sphere" size="0.05" rgba="0.9 0.3 0.3 0.5"/>
    </body>
  </worldbody>
</mujoco>
