<mujoco model="ironarm_4dof">
  <compiler angle="radian"/>

  <visual>
    <global offwidth="2048" offheight="2048"/>
  </visual>

  <worldbody>
    <!-- Floor -->
    <geom type="plane" size="3 3 0.1" rgba="0.28 0.28 0.32 1"/>

    <!-- Base pedestal -->
    <body name="base" pos="0 0 0">
      <geom type="cylinder" size="0.08 0.15" pos="0 0 0.075" rgba="0.45 0.45 0.50 1"/>
      <geom type="box" size="0.12 0.005 0.12" pos="0 0 0.005" rgba="0.40 0.40 0.42 1"/>
    </body>

    <!-- Waist: j0 around Z -->
    <body name="waist" pos="0 0 0.15">
      <joint name="j0" type="hinge" axis="0 0 1"/>
      <geom type="cylinder" size="0.06 0.06" rgba="0.55 0.55 0.60 1"/>

      <!-- Shoulder: j1 around Y -->
      <body name="shoulder" pos="0 0 0.03">
        <joint name="j1" type="hinge" axis="0 1 0" range="-2.0 2.0"/>
        <geom type="sphere" size="0.05" rgba="0.75 0.75 0.75 1"/>

        <!-- Upper arm L1 = 0.8 -->
        <body name="upper_arm" pos="0 0 0">
          <geom type="capsule" size="0.04" fromto="0 0 0 0.8 0 0" rgba="0.35 0.65 0.95 1"/>

          <!-- Elbow: j2 around Y -->
          <body name="elbow" pos="0.8 0 0">
            <joint name="j2" type="hinge" axis="0 1 0" range="-0.5 3.0"/>
            <geom type="sphere" size="0.04" rgba="0.75 0.75 0.75 1"/>

            <!-- Forearm L2 = 0.7 -->
            <body name="forearm" pos="0 0 0">
              <geom type="capsule" size="0.04" fromto="0 0 0 0.7 0 0" rgba="0.35 0.75 0.45 1"/>

              <!-- Wrist: j3 around Y -->
              <body name="wrist" pos="0.7 0 0">
                <joint name="j3" type="hinge" axis="0 1 0" range="-2.0 2.0"/>
                <geom type="sphere" size="0.03" rgba="0.85 0.85 0.85 1"/>

                <!-- Wrist extension L3 = 0.15 -->
                <body name="wrist_ext" pos="0 0 0">
                  <geom type="capsule" size="0.025" fromto="0 0 0 0.15 0 0" rgba="1.0 0.6 0.2 1"/>

                  <!-- End-effector tip -->
                  <body name="ee" pos="0.15 0 0">
                    <geom type="sphere" size="0.025" rgba="1.0 0.3 0.3 0.9"/>
                  </body>
                </body>
              </body>
            </body>
          </body>
        </body>
      </body>
    </body>

    <!-- Target marker -->
    <body name="target" pos="1.0 0 0.8">
      <freejoint/>
      <geom type="sphere" size="0.05" rgba="0.9 0.3 0.3 0.5"/>
    </body>
  </worldbody>
</mujoco>
