// 机械臂模型参数（保存后自动热重载，无需重启程序）
// ============================================================
//
// 布局：base(地面) → joint0(Y轴) → link0(竖直) → joint1(Z轴) → link1(水平)
// anchor1/2 的世界坐标必须在初始状态对齐，否则关节会悬空
//
// 调整方法：改任意数值 → 保存 → GUI 自动更新（约 1 秒延迟）

(
    // ── 底座（Static 刚体，固定不动）────────────────────────────
    base: (
        size:   (0.5, 0.5, 0.5),     // (长X, 高Y, 宽Z) 米
        center: (0.0, 0.25, 0.0),    // 几何中心的世界坐标 (X, Y, Z)
    ),

    // ── 大臂（Dynamic 刚体，受重力+电机驱动）─────────────────────
    link0: (
        size:   (0.2, 1.0, 0.2),     // 细长竖直杆
        center: (0.0, 1.0, 0.0),     // 底端对齐 base 顶部
    ),

    // ── 小臂（Dynamic 刚体，受重力+电机驱动）─────────────────────
    link1: (
        size:   (2.0, 0.15, 0.15),   // 长扁水平杆
        center: (1.0, 1.65, 0.0),    // 左端对齐 link0 顶部
    ),

    // ── 关节 0：底座 → 大臂 ─────────────────────────────────────
    joint0: (
        axis: Y,                      // 旋转轴（X=前后摆, Y=水平转, Z=上下摆）
        anchor1: (0.0, 0.25, 0.0),   // 底座上的铰接点（相对底座中心）
        anchor2: (0.0, -0.5, 0.0),   // 大臂上的铰接点（相对大臂中心）

        motor_frequency: 5.0,         // 电机刚度 Hz（2=很软像弹簧, 10=很硬像伺服）
        motor_damping_ratio: 1.0,     // 阻尼比（0=来回振荡, 1=临界阻尼不超调, 2=慵懒缓慢）
        angle_limit_min: -1.57,       // 角度下限 rad（-1.57 = -90°）
        angle_limit_max: 1.57,        // 角度上限 rad（+1.57 = +90°）
    ),

    // ── 关节 1：大臂 → 小臂 ─────────────────────────────────────
    joint1: (
        axis: Z,                      // 绕 Z 轴（上下摆动小臂）
        anchor1: (0.0, 0.5, 0.0),    // 大臂顶部铰接点（相对大臂中心）
        anchor2: (-1.0, -0.15, 0.0), // 小臂左端铰接点（相对小臂中心）

        motor_frequency: 5.0,         // 同上
        motor_damping_ratio: 1.0,     // 同上
        angle_limit_min: -1.57,       // 同上（-90°）
        angle_limit_max: 1.57,        // 同上（+90°）
    ),

    // ── 全局物理参数 ────────────────────────────────────────────
    linear_damping: 0.5,              // 线性阻尼（0=无阻力滑冰, 0.5=油阻尼, 2=糖浆）
    angular_damping: 0.5,             // 角阻尼（控制旋转减速，同上尺度）
)
