# Python 仿真项目

[group('run')]
run:
    @rm -rf .venv/lib/python*/site-packages/ironarm_sim*
    @uv run maturin develop --release
    @uv run --no-sync python -m src.main

[group('check')]
lint:
    @uv run ruff check .

[group('check')]
fmt:
    @uv run ruff format .

[group('check')]
typecheck:
    @uv run mypy .

[group('check')]
test:
    @uv run pytest .
