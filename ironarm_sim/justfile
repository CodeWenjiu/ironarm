# Python 仿真项目

# Debug 构建 Rust 扩展
[group('build')]
build:
    @uv run maturin develop --uv

# Release 构建 Rust 扩展
[group('build')]
build-release:
    @uv run maturin develop --uv --release

# 运行仿真（需先 build）
[group('run')]
run:
    @uv run main.py

[group('check')]
lint:
    @uv run ruff check .

[group('check')]
fmt:
    @uv run ruff format .

[group('check')]
typecheck:
    @uv run mypy .

[group('check')]
test:
    @uv run pytest .
